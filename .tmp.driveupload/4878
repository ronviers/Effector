    if not (ec < er < ee):
        print_error(
            f"IEP epsilon thresholds must satisfy:\n"
            f"  epsilon_continue ({ec}) < epsilon_replan ({er}) < epsilon_escalate ({ee})\n"
            "Adjust with --epsilon-continue / --epsilon-replan / --epsilon-escalate."
        )
