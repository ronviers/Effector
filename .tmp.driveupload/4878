    # ── Delegate to run_cmd ───────────────────────────────────────────────────
    exit_code = execute_run(
        task=task,
        agent1_model=resolved_agent1,
        agent2_model=resolved_agent2,
        arbiter_model=resolved_arbiter,
        agent1_temp=resolved_a1_temp,
